{
    "description": "Error handling and exception scenarios",
    "cases": [
        {
            "input": {
                "operation": "add_new_key",
                "key": "age",
                "default": 0
            },
            "expected_output": {
                "status": "success",
                "all_records_have_key": true
            }
        },
        {
            "input": {
                "operation": "add_new_key",
                "key": "name",
                "default": ""
            },
            "expected_output": {
                "status": "success",
                "all_records_have_key": true
            }
        },
        {
            "input": {
                "operation": "get_by_id",
                "id": "non_existent_123"
            },
            "expected_output": {
                "status": "error",
                "error_type": "IdDoesNotExistError"
            }
        },
        {
            "input": {
                "operation": "add",
                "data": {
                    "unknown_field": "value"
                }
            },
            "expected_output": {
                "status": "error",
                "error_type": "UnknownKeyError"
            }
        },
        {
            "input": {
                "operation": "load_corrupted",
                "db_file": "corrupted.json"
            },
            "expected_output": {
                "status": "error",
                "error_type": "SchemaTypeError"
            }
        },
        {
            "input": {
                "operation": "add",
                "data": "not_a_dict"
            },
            "expected_output": {
                "status": "error",
                "error_type": "TypeError"
            }
        },
        {
            "input": {
                "operation": "add",
                "data": {
                    "age": 30
                }
            },
            "expected_output": {
                "status": "error",
                "error_type": "UnknownKeyError"
            }
        },
        {
            "input": {
                "operation": "add",
                "data": {
                    "age": 25,
                    "name": "Test"
                }
            },
            "expected_output": {
                "status": "success",
                "id_length": 18
            }
        },
        {
            "input": {
                "operation": "update_by_id",
                "id": "placeholder",
                "new_data": {
                    "unknown": "value"
                }
            },
            "expected_output": {
                "status": "error",
                "error_type": "UnknownKeyError"
            }
        },
        {
            "input": {
                "operation": "update_by_id",
                "id": "non_existent_999",
                "new_data": {
                    "age": 99
                }
            },
            "expected_output": {
                "status": "error",
                "error_type": "IdDoesNotExistError"
            }
        },
        {
            "input": {
                "operation": "add_many",
                "data": {}
            },
            "expected_output": {
                "status": "error",
                "error_type": "TypeError"
            }
        },
        {
            "input": {
                "operation": "add_many",
                "data": [
                    {
                        "age": 1,
                        "name": "ok"
                    },
                    "not dict"
                ]
            },
            "expected_output": {
                "status": "error",
                "error_type": "TypeError"
            }
        },
        {
            "input": {
                "operation": "get_by_query",
                "query": 123
            },
            "expected_output": {
                "status": "error",
                "error_type": "TypeError"
            }
        }
    ]
}