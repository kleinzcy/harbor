{
    "description": "Given a dictionary as comma-separated key:value pairs, print all values sorted by their key alphabetically, one per line.",
    "cases": [
        {
            "input": "a:1,b:2,c:3",
            "expected_output": "1\\n2\\n3"
        },
        {
            "input": "z:1,a:2,m:3",
            "expected_output": "2\\n3\\n1"
        },
        {
            "input": "x:10",
            "expected_output": "10"
        },
        {
            "input": "b:2,a:1,d:4,c:3",
            "expected_output": "1\\n2\\n3\\n4"
        },
        {
            "input": "cat:1,ant:2,bat:3",
            "expected_output": "2\\n3\\n1"
        }
    ]
}