{
    "description": "Test command line interface functionality - enhanced",
    "cases": [
        {
            "input": {
                "command": ["gitingest", "/tmp/test-project"],
                "working_dir": "/tmp"
            },
            "expected_output": {
                "exit_code": 0,
                "creates_digest": true,
                "contains_structure": true
            }
        },
        {
            "input": {
                "command": ["gitingest", "/tmp/test-local-repo"],
                "working_dir": "/tmp"
            },
            "expected_output": {
                "exit_code": 0,
                "creates_digest": true,
                "contains_hello_world": false
            }
        },
        {
            "input": {
                "command": [
                    "gitingest", ".",
                    "--exclude-pattern", "*.pyc",
                    "--exclude-pattern", "__pycache__/",
                    "--include-pattern", "*.py"
                ],
                "working_dir": "/tmp/test-project"
            },
            "expected_output": {
                "exit_code": 0,
                "includes_py": true,
                "excludes_pyc": true
            }
        },
        {
            "input": {
                "command": ["gitingest", ".", "--output", "-"],
                "working_dir": "/tmp/test-project"
            },
            "expected_output": {
                "exit_code": 0,
                "stdout_contains_structure": true,
                "no_digest_file": true
            }
        },
        {
            "input": {
                "command": ["gitingest", "/tmp/nonexistent-path"],
                "working_dir": "/tmp"
            },
            "expected_output": {
                "exit_code": 1
            }
        },
        {
            "input": {
                "command": ["gitingest", "https://github.com/octocat/Hello-World"],
                "working_dir": "/tmp"
            },
            "expected_output": {
                "exit_code": 0,
                "contains_hello_world": true,
                "creates_digest": true
            }
        },
        {
            "input": {
                "command": ["gitingest", "https://github.com/octocat/Hello-World", "--output", "output.json"],
                "working_dir": "/tmp"
            },
            "expected_output": {
                "exit_code": 0,
                "creates_digest": true,
                "no_digest_file": false
            }
        },
        {
            "input": {
                "command": ["gitingest", ".", "--branch", "main", "--token", "ghp_xxx", "--subpath", "/src"],
                "working_dir": "/tmp/test-project"
            },
            "expected_output": {
                "exit_code": 0,
                "creates_digest": true
            }
        },
        {
            "input": {
                "command": ["gitingest", ".", "--max-file-size", "1024", "--no-gitignore"],
                "working_dir": "/tmp/test-project"
            },
            "expected_output": {
                "exit_code": 0,
                "creates_digest": true
            }
        },
        {
            "input": {
                "command": ["gitingest", ".", "--format", "json"],
                "working_dir": "/tmp/test-project"
            },
            "expected_output": {
                "exit_code": 0,
                "creates_digest": true
            }
        }
    ]
}