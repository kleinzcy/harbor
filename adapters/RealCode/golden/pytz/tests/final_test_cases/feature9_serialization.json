{
  "description": "Test pickle serialization and deserialization of timezone objects, verifying singleton preservation.",
  "cases": [
    {
      "input": {
        "zone": "US/Eastern"
      },
      "expected_output": {
        "same_object_after_roundtrip": true,
        "zone": "US/Eastern"
      }
    },
    {
      "input": {
        "zone": "UTC"
      },
      "expected_output": {
        "same_object_after_roundtrip": true,
        "zone": "UTC"
      }
    },
    {
      "input": {
        "zone": "Asia/Shanghai"
      },
      "expected_output": {
        "same_object_after_roundtrip": true,
        "zone": "Asia/Shanghai"
      }
    },
    {
      "input": {
        "zone": "GMT"
      },
      "expected_output": {
        "same_object_after_roundtrip": true,
        "zone": "GMT"
      }
    },
    {
      "input": {
        "type": "FixedOffset",
        "offset_minutes": 480
      },
      "expected_output": {
        "same_object_after_roundtrip": true,
        "repr": "pytz.FixedOffset(480)"
      }
    },
    {
      "input": {
        "zone": "UTC",
        "check": "compact_serialization"
      },
      "expected_output": {
        "utc_smaller_than_dst": true
      }
    },
    {
      "input": {
        "zone": "Europe/London"
      },
      "expected_output": {
        "same_object_after_roundtrip": true,
        "zone": "Europe/London"
      }
    },
    {
      "input": {
        "zone": "America/Los_Angeles"
      },
      "expected_output": {
        "same_object_after_roundtrip": true,
        "zone": "America/Los_Angeles"
      }
    },
    {
      "input": {
        "type": "FixedOffset",
        "offset_minutes": -300
      },
      "expected_output": {
        "same_object_after_roundtrip": true,
        "repr": "pytz.FixedOffset(-300)"
      }
    },
    {
      "input": {
        "type": "FixedOffset",
        "offset_minutes": 0
      },
      "expected_output": {
        "same_object_after_roundtrip": true,
        "repr": "pytz.FixedOffset(0)"
      }
    }
  ]
}