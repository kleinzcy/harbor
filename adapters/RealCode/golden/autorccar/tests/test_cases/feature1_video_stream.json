{
    "description": "Test JPEG frame decoding and ROI extraction",
    "cases": [
        {
            "input": "base64_encoded_jpeg_frame",
            "expected_output": {
                "width": 320,
                "height": 240,
                "roi_shape": [120, 320],
                "format": "gray"
            }
        },
        {
            "input": "",
            "expected_output": {"error": "No input provided"}
        },
        {
            "input": "not a base64 string",
            "expected_output": {
                "width": 320,
                "height": 240,
                "roi_shape": [120, 320],
                "format": "gray"
            }
        },
        {
            "input": "{\"input\": \"base64_encoded_jpeg_frame\"}",
            "expected_output": {
                "width": 320,
                "height": 240,
                "roi_shape": [120, 320],
                "format": "gray"
            }
        },
        {
            "input": "{}",
            "expected_output": {
                "width": 320,
                "height": 240,
                "roi_shape": [120, 320],
                "format": "gray"
            }
        },
        {
            "input": "{",
            "expected_output": {"error": "Invalid JSON input"}
        },
        {
            "input": "{\"extra\": \"field\"}",
            "expected_output": {
                "width": 320,
                "height": 240,
                "roi_shape": [120, 320],
                "format": "gray"
            }
        }
    ]
}