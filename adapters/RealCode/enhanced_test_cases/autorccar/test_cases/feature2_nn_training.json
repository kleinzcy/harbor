{
    "description": "Test neural network creation, training, and prediction",
    "cases": [
        {
            "input": {"layer_sizes": [76800, 32, 4]},
            "expected_output": {"status": "model_created"}
        },
        {
            "input": {"X_train_shape": [100, 76800], "y_train_shape": [100, 4]},
            "expected_output": {"status": "training_completed"}
        },
        {
            "input": {"X_test_sample": [0.1, 0.2, 0.3]},
            "expected_output": {"prediction": 2}
        },
        {
            "input": "",
            "expected_output": {"error": "No input provided"}
        },
        {
            "input": "{",
            "expected_output": {"error": "Invalid JSON input"}
        },
        {
            "input": {},
            "expected_output": {"error": "Unknown operation. Supported: layer_sizes, X_train_shape/y_train_shape, X_test_sample"}
        },
        {
            "input": {"layer_sizes": []},
            "expected_output": {"status": "model_created"}
        },
        {
            "input": {"layer_sizes": [0, -1, 5]},
            "expected_output": {"status": "model_created"}
        },
        {
            "input": {"X_train_shape": [100], "y_train_shape": [100, 4]},
            "expected_output": {"error": "Invalid shape dimensions"}
        },
        {
            "input": {"X_train_shape": [100, 76800], "y_train_shape": [100]},
            "expected_output": {"error": "Invalid shape dimensions"}
        },
        {
            "input": {"X_test_sample": []},
            "expected_output": {"prediction": 2}
        },
        {
            "input": {"X_test_sample": "not a list"},
            "expected_output": {"prediction": 2}
        },
        {
            "input": {"layer_sizes": [76800, 32, 4], "X_train_shape": [100, 76800], "y_train_shape": [100, 4]},
            "expected_output": {"status": "model_created"}
        },
        {
            "input": {"X_train_shape": [100, 76800], "y_train_shape": [100, 4], "X_test_sample": [0.1]},
            "expected_output": {"status": "training_completed"}
        }
    ]
}