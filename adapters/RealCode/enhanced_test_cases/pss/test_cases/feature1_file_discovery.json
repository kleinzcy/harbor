                "/Users/pengzhongyuan/PythonCode/realcode_bench/workspaces/pss/test_data/src/main.py",
                "/Users/pengzhongyuan/PythonCode/realcode_bench/workspaces/pss/test_data/src/vendor/external.js"
            ]
        },
