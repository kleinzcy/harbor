{
    "description": "Basic HTML text extraction with simple paragraphs",
    "cases": [
        {
            "input": "<p>Hello world</p>",
            "expected_output": "Hello world"
        },
        {
            "input": "<div><p>First paragraph</p><p>Second paragraph</p></div>",
            "expected_output": "First paragraph\nSecond paragraph"
        },
        {
            "input": "<h1>Title</h1><p>Content</p>",
            "expected_output": "Title\nContent"
        },
        {
            "input": "",
            "expected_output": ""
        },
        {
            "input": "   ",
            "expected_output": ""
        },
        {
            "input": "<div><p><span>Nested</span> text</p></div>",
            "expected_output": "Nested text"
        },
        {
            "input": "<p>Hello <strong>world</strong>!</p>",
            "expected_output": "Hello world !"
        },
        {
            "input": "<h1>Title1</h1><h2>Title2</h2>",
            "expected_output": "Title1\nTitle2"
        },
        {
            "input": "<ul><li>Item1</li><li>Item2</li></ul>",
            "expected_output": "Item1\nItem2"
        },
        {
            "input": "<table><tr><td>Cell1</td><td>Cell2</td></tr></table>",
            "expected_output": "Cell1\nCell2"
        },
        {
            "input": "<div><h1>Header</h1><p>Paragraph</p><ul><li>Item</li></ul></div>",
            "expected_output": "Header\nParagraph"
        },
        {
            "input": "<p>Line1<br>Line2</p>",
            "expected_output": "Line1 \n Line2"
        },
        {
            "input": "<p>Hello 世界 🌍</p>",
            "expected_output": "Hello 世界 🌍"
        },
        {
            "input": "<p>AT&amp;T &copy; 2025</p>",
            "expected_output": "AT&T © 2025"
        },
        {
            "input": "<div><div><p>Inner paragraph</p></div></div>",
            "expected_output": "Inner paragraph"
        },
        {
            "input": "<p>Text with   multiple   spaces</p>",
            "expected_output": "Text with   multiple   spaces"
        }
    ]
}