{
    "description": "Database utilities for migration, merging, and export",
    "cases": [
        {
            "input": {
                "operation": "migrate",
                "old_data": {
                    "data": [
                        {
                            "id": 1,
                            "name": "Test",
                            "age": 20
                        }
                    ]
                }
            },
            "expected_output": {
                "status": "success",
                "has_version": 2,
                "has_keys": true,
                "data_count": 1
            }
        },
        {
            "input": {
                "operation": "merge",
                "databases": [
                    {
                        "version": 2,
                        "keys": [
                            "name",
                            "age"
                        ],
                        "data": {
                            "1": {
                                "name": "A",
                                "age": 25
                            }
                        }
                    },
                    {
                        "version": 2,
                        "keys": [
                            "name",
                            "age"
                        ],
                        "data": {
                            "2": {
                                "name": "B",
                                "age": 30
                            }
                        }
                    }
                ]
            },
            "expected_output": {
                "status": "success",
                "merged_keys": [
                    "age",
                    "name"
                ],
                "total_records": 2
            }
        },
        {
            "input": {
                "operation": "purge_db",
                "input": "any"
            },
            "expected_output": {
                "status": "success",
                "structure": {
                    "version": 2,
                    "keys": [],
                    "data": {}
                }
            }
        },
        {
            "input": {
                "operation": "merge",
                "databases": [
                    {
                        "version": 2,
                        "keys": [
                            "name",
                            "age"
                        ],
                        "data": {
                            "1": {
                                "name": "A",
                                "age": 25
                            }
                        }
                    },
                    {
                        "version": 2,
                        "keys": [
                            "age",
                            "email"
                        ],
                        "data": {
                            "2": {
                                "age": 30,
                                "email": "test@example.com"
                            }
                        }
                    }
                ]
            },
            "expected_output": {
                "status": "error",
                "error_type": "ValueError"
            }
        },
        {
            "input": {
                "operation": "merge",
                "databases": [
                    {
                        "version": 2,
                        "keys": [
                            "name",
                            "age"
                        ],
                        "data": {
                            "1": {
                                "name": "A",
                                "age": 25
                            }
                        }
                    },
                    {
                        "version": 2,
                        "keys": [
                            "name",
                            "age"
                        ],
                        "data": {
                            "1": {
                                "name": "B",
                                "age": 30
                            }
                        }
                    }
                ]
            },
            "expected_output": {
                "status": "success",
                "total_records": 2
            }
        },
        {
            "input": {
                "operation": "migrate",
                "old_data": {}
            },
            "expected_output": {
                "status": "error",
                "error_type": "SchemaTypeError"
            }
        },
        {
            "input": {
                "operation": "migrate",
                "old_data": {
                    "data": [
                        {
                            "id": 1
                        },
                        "invalid"
                    ]
                }
            },
            "expected_output": {
                "status": "success",
                "has_version": true,
                "has_keys": true,
                "data_count": 1
            }
        },
        {
            "input": {
                "operation": "merge",
                "databases": []
            },
            "expected_output": {
                "status": "success",
                "merged_keys": [],
                "total_records": 0
            }
        },
        {
            "input": {
                "operation": "purge_db",
                "input": null
            },
            "expected_output": {
                "status": "success",
                "structure": {
                    "version": 2,
                    "keys": [],
                    "data": {}
                }
            }
        }
    ]
}