{
    "description": "Test FixedOffset timezone creation, offset calculation, singleton caching, and datetime formatting.",
    "cases": [
        {
            "input": {
                "offset_minutes": 480,
                "datetime": "2002-10-27 06:00:00"
            },
            "expected_output": {
                "formatted": "2002-10-27 06:00:00 (+0800)",
                "utcoffset": "8:00:00",
                "dst": "0:00:00",
                "repr": "pytz.FixedOffset(480)"
            }
        },
        {
            "input": {
                "offset_minutes": -300,
                "datetime": "2002-10-27 06:00:00"
            },
            "expected_output": {
                "formatted": "2002-10-27 06:00:00 (-0500)",
                "utcoffset": "-1 day, 19:00:00",
                "dst": "0:00:00",
                "repr": "pytz.FixedOffset(-300)"
            }
        },
        {
            "input": {
                "offset_minutes": 0,
                "datetime": "2002-10-27 06:00:00"
            },
            "expected_output": {
                "formatted": "2002-10-27 06:00:00 (+0000)",
                "utcoffset": "0:00:00",
                "dst": "0:00:00",
                "repr": "pytz.FixedOffset(0)"
            }
        },
        {
            "input": {
                "offset_minutes": 540,
                "datetime": "2002-10-27 06:00:00"
            },
            "expected_output": {
                "formatted": "2002-10-27 06:00:00 (+0900)",
                "utcoffset": "9:00:00",
                "dst": "0:00:00",
                "repr": "pytz.FixedOffset(540)"
            }
        },
        {
            "input": {
                "action": "singleton_check",
                "offset_minutes": 480
            },
            "expected_output": {
                "same_object": true
            }
        },
        {
            "input": {
                "offset_minutes": 840,
                "datetime": "2002-10-27 06:00:00"
            },
            "expected_output": {
                "formatted": "2002-10-27 06:00:00 (+1400)",
                "utcoffset": "14:00:00",
                "dst": "0:00:00",
                "repr": "pytz.FixedOffset(840)"
            }
        },
        {
            "input": {
                "offset_minutes": -720,
                "datetime": "2002-10-27 06:00:00"
            },
            "expected_output": {
                "formatted": "2002-10-27 06:00:00 (-1200)",
                "utcoffset": "-1 day, 12:00:00",
                "dst": "0:00:00",
                "repr": "pytz.FixedOffset(-720)"
            }
        },
        {
            "input": {
                "offset_minutes": 5,
                "datetime": "2002-10-27 06:00:00"
            },
            "expected_output": {
                "formatted": "2002-10-27 06:00:00 (+0005)",
                "utcoffset": "0:05:00",
                "dst": "0:00:00",
                "repr": "pytz.FixedOffset(5)"
            }
        },
        {
            "input": {
                "offset_minutes": -123,
                "datetime": "2002-10-27 06:00:00"
            },
            "expected_output": {
                "formatted": "2002-10-27 06:00:00 (-0203)",
                "utcoffset": "-1 day, 21:57:00",
                "dst": "0:00:00",
                "repr": "pytz.FixedOffset(-123)"
            }
        },
        {
            "input": {
                "action": "singleton_check",
                "offset_minutes": 0
            },
            "expected_output": {
                "same_object": true
            }
        },
        {
            "input": {
                "action": "singleton_check",
                "offset_minutes": -300
            },
            "expected_output": {
                "same_object": true
            }
        }
    ]
}