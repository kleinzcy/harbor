{
    "description": "Test web API endpoints for repository ingestion - enhanced",
    "cases": [
        {
            "input": {
                "endpoint": "/api/ingest",
                "method": "POST",
                "payload": {
                    "input_text": "/tmp/test-local-repo",
                    "max_file_size": 5120,
                    "pattern_type": "exclude",
                    "pattern": "",
                    "token": null
                }
            },
            "expected_output": {
                "status_code": 200,
                "has_summary": true,
                "has_tree": true,
                "has_content": true,
                "contains_repo_name": true
            }
        },
        {
            "input": {
                "endpoint": "/api/ingest",
                "method": "POST",
                "payload": {
                    "input_text": "/tmp/nonexistent-repo",
                    "max_file_size": 5120,
                    "pattern_type": "exclude",
                    "pattern": "",
                    "token": null
                }
            },
            "expected_output": {
                "status_code": 400,
                "error_contains_auth": true
            }
        },
        {
            "input": {
                "endpoint": "/api/ingest",
                "method": "POST",
                "payload": {
                    "input_text": "/tmp/test-local-repo",
                    "max_file_size": 5120,
                    "pattern_type": "include",
                    "pattern": "*.py,*.md",
                    "token": null
                }
            },
            "expected_output": {
                "status_code": 200,
                "includes_py_md": true,
                "excludes_other_formats": true
            }
        },
        {
            "input": {
                "endpoint": "/api/health",
                "method": "GET",
                "payload": {}
            },
            "expected_output": {
                "status_code": 200,
                "status": "healthy"
            }
        },
        {
            "input": {
                "endpoint": "/api/status",
                "method": "GET",
                "payload": {}
            },
            "expected_output": {
                "status_code": 200,
                "status": "running"
            }
        },
        {
            "input": {
                "endpoint": "/api/ingest",
                "method": "POST",
                "payload": {}
            },
            "expected_output": {
                "status_code": 400,
                "error_contains_auth": false
            }
        },
        {
            "input": {
                "endpoint": "/api/ingest",
                "method": "POST",
                "payload": {
                    "input_text": "",
                    "max_file_size": 5120
                }
            },
            "expected_output": {
                "status_code": 400,
                "error_contains_auth": false
            }
        },
        {
            "input": {
                "endpoint": "/api/ingest",
                "method": "POST",
                "payload": {
                    "input_text": "github.com/user/private",
                    "max_file_size": 5120,
                    "token": null
                }
            },
            "expected_output": {
                "status_code": 400,
                "error_contains_auth": true
            }
        },
        {
            "input": {
                "endpoint": "/api/ingest",
                "method": "POST",
                "payload": {
                    "input_text": "github.com/user/private",
                    "max_file_size": 5120,
                    "token": "ghp_xxxxxxxxxxxxx"
                }
            },
            "expected_output": {
                "status_code": 200,
                "has_summary": true
            }
        },
        {
            "input": {
                "endpoint": "/api/ingest",
                "method": "POST",
                "payload": {
                    "input_text": "github.com/octocat/Hello-World",
                    "max_file_size": 5120
                }
            },
            "expected_output": {
                "status_code": 200,
                "contains_repo_name": true,
                "has_summary": true,
                "has_tree": true,
                "has_content": true
            }
        },
        {
            "input": {
                "endpoint": "/api/ingest",
                "method": "POST",
                "payload": {
                    "input_text": "github.com/user/repo",
                    "max_file_size": 5120,
                    "pattern_type": "include",
                    "pattern": "*.py"
                }
            },
            "expected_output": {
                "status_code": 200,
                "includes_py_md": false,
                "excludes_other_formats": false
            }
        },
        {
            "input": {
                "endpoint": "/api/ingest",
                "method": "GET",
                "payload": {}
            },
            "expected_output": {
                "status_code": 404
            }
        },
        {
            "input": {
                "endpoint": "/api/nonexistent",
                "method": "POST",
                "payload": {}
            },
            "expected_output": {
                "status_code": 404
            }
        }
    ]
}