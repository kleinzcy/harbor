{
    "description": "Given a string, push it onto a queue then pop and print it.",
    "cases": [
        {
            "input": "hello",
            "expected_output": "hello"
        },
        {
            "input": "world",
            "expected_output": "world"
        },
        {
            "input": "test message",
            "expected_output": "test message"
        },
        {
            "input": "12345",
            "expected_output": "12345"
        },
        {
            "input": "a",
            "expected_output": "a"
        },
        {
            "input": "foo bar baz",
            "expected_output": "foo bar baz"
        },
        {
            "input": "",
            "expected_output": ""
        },
        {
            "input": "   ",
            "expected_output": ""
        },
        {
            "input": "caf\u00e9",
            "expected_output": "caf\u00e9"
        },
        {
            "input": "",
            "expected_output": ""
        },
        {
            "input": "\\",
            "expected_output": "\\"
        },
        {
            "input": "hello\t",
            "expected_output": "hello"
        },
        {
            "input": "  spaced out  ",
            "expected_output": "spaced out"
        },
        {
            "input": "multiple   spaces",
            "expected_output": "multiple   spaces"
        },
        {
            "input": "123\t456",
            "expected_output": "123\t456"
        }
    ]
}