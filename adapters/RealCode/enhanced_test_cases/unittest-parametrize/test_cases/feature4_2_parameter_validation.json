{
  "description": "Parameter validation and type checking",
  "cases": [
    {
      "input": {
        "argnames": "x,y",
        "argvalues": [
          [
            1
          ]
        ]
      },
      "expected_output": {
        "error": "tuple at index 0 has wrong number of arguments (1 != 2)"
      }
    },
    {
      "input": {
        "argnames": "x",
        "argvalues": [
          {
            "x": 1
          }
        ]
      },
      "expected_output": {
        "error": "argvalue at index 0 is not a tuple or param instance"
      }
    },
    {
      "input": {
        "argnames": "x",
        "argvalues": [
          1,
          2,
          3
        ]
      },
      "expected_output": {
        "generated_methods": [
          "test_single_values_0",
          "test_single_values_1",
          "test_single_values_2"
        ]
      }
    },
    {
      "input": {
        "argnames": "a,b",
        "argvalues": [
          [
            [
              1,
              2
            ],
            "hello"
          ],
          [
            [
              3,
              4
            ],
            "world"
          ]
        ]
      },
      "expected_output": {
        "generated_methods": [
          "test_nested_0",
          "test_nested_1"
        ]
      }
    },
    {
      "input": {
        "argnames": "x,y",
        "argvalues": [
          {
            "__type__": "param",
            "args": [
              1
            ]
          }
        ]
      },
      "expected_output": {
        "error": "param object at index 0 has wrong number of arguments"
      }
    },
    {
      "input": {
        "argnames": "x,y",
        "argvalues": [
          1
        ]
      },
      "expected_output": {
        "error": "argvalue at index 0 is not a tuple or param instance"
      }
    }
  ]
}